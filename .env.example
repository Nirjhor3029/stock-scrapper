# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/dse_scraper

# DSE Website URL
DSE_URL=https://www.dsebd.org/latest_share_price_scroll_by_value.php

# Cache Configuration (in minutes)
CACHE_DURATION_MINUTES=5

# Trading Hours Configuration (Bangladesh timezone UTC+6)
# DSE trading hours: 10:00 AM - 2:45 PM BST
TRADING_START_HOUR=10
TRADING_START_MINUTE=0
TRADING_END_HOUR=14
TRADING_END_MINUTE=45
TRADING_DAYS=0,1,2,3,4  # 0=Sunday, 1=Monday, ..., 4=Thursday (Bangladesh work week)

# Logging Level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info